# MotusGridia — environment variable template.
# Copy to `.env.local` and fill in. `.env.local` is .gitignored.
# All publicly-exposed vars MUST be prefixed `NEXT_PUBLIC_`.

# ---------------------------------------------------------------------------
# Site
# ---------------------------------------------------------------------------

# Public URL — used by next/sitemap, OG metadata, JSON-LD canonical.
# Keep in sync with the `metadataBase` in /site/app/layout.tsx.
NEXT_PUBLIC_SITE_URL="https://motusgridia.com"

# ---------------------------------------------------------------------------
# Resend — newsletter audience-add for the v0.1 form
# Stack: /stack-recommendation.md § TL;DR
# Wires the /api/subscribe server action.
# Get a key at https://resend.com/api-keys (Shaan's Resend account).
# ---------------------------------------------------------------------------

RESEND_API_KEY=""
# Audience UUID from https://resend.com/audiences — the "wall".
RESEND_AUDIENCE_ID=""

# ---------------------------------------------------------------------------
# Cloudflare Turnstile — spam protection on the newsletter form
# Stack: /stack-recommendation.md § TL;DR
# Set up at https://dash.cloudflare.com → Turnstile → Add site.
#
# Activation contract (app/api/subscribe/route.ts + app/components/SubscribeForm.tsx):
#   - Both keys unset  → form renders the disabled v0.0 shell; route returns 503.
#   - Both keys set    → form is live end-to-end.
#   - Only one set     → partial state — client will POST, server stays pending.
#                        Avoid this configuration.
#
# Local dev without registering a site: Cloudflare publishes test keys at
#   https://developers.cloudflare.com/turnstile/troubleshooting/testing/
# The common pair is "always passes":
#   NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
#   TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
# There's also "always blocks" / "always challenges" / invisible variants
# at the same doc URL — useful for QA-ing the error branch.
# ---------------------------------------------------------------------------

NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# ---------------------------------------------------------------------------
# Vercel Analytics + Plausible (deferred — wire only when ready to ship)
# ---------------------------------------------------------------------------

# NEXT_PUBLIC_PLAUSIBLE_DOMAIN="motusgridia.com"
# (Vercel Analytics auto-wires via @vercel/analytics — no env var needed.)
